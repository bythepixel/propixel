generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  VIEWER
  EDITOR
  APPROVER
  PUBLISHER
  ADMIN
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         Role       @default(EDITOR)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  proposals    Proposal[]
  auditLogs    AuditLog[]
}

model Category {
  id     String         @id @default(cuid())
  name   String         @unique
  blocks ContentBlock[]
}

model Tag {
  id     String            @id @default(cuid())
  name   String            @unique
  blocks ContentBlockTag[]
}

model ContentBlock {
  id               String            @id @default(cuid())
  title            String
  body             String
  usageGuidance    String?
  sensitive        Boolean           @default(false)
  visualTemplateId String?
  visualTemplate   BlockVisualTemplate? @relation(fields: [visualTemplateId], references: [id])
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id])
  tags             ContentBlockTag[]
  templateSections TemplateSection[] @relation("DefaultBlock")
  proposalSections ProposalSection[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model BlockVisualTemplate {
  id        String         @id @default(cuid())
  name      String         @unique
  html      String
  css       String
  js        String
  blocks    ContentBlock[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ContentBlockTag {
  blockId String
  tagId   String
  block   ContentBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  tag     Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blockId, tagId])
}

model Template {
  id          String            @id @default(cuid())
  name        String
  description String?
  visualTemplateId String?
  visualTemplate   VisualTemplate? @relation(fields: [visualTemplateId], references: [id])
  sections    TemplateSection[]
  proposals   Proposal[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model VisualTemplate {
  id        String     @id @default(cuid())
  name      String     @unique
  html      String
  css       String
  js        String
  templates Template[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model TemplateSection {
  id             String        @id @default(cuid())
  templateId     String
  template       Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order          Int
  sectionTitle   String
  defaultBlockId String?
  defaultBlock   ContentBlock? @relation("DefaultBlock", fields: [defaultBlockId], references: [id])
}

model Proposal {
  id              String            @id @default(cuid())
  title           String
  authorId        String
  author          User              @relation(fields: [authorId], references: [id])
  templateId      String?
  template        Template?         @relation(fields: [templateId], references: [id])
  shareToken      String?           @unique
  published       Boolean           @default(false)
  discountPercent Float             @default(0)
  sections        ProposalSection[]
  lineItems       PricingLineItem[]
  attachments     Attachment[]
  embeds          ProposalEmbed[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ProposalSection {
  id             String       @id @default(cuid())
  proposalId     String
  proposal       Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  order          Int
  contentBlockId String
  contentBlock   ContentBlock @relation(fields: [contentBlockId], references: [id])
  overrideBody   String?
}

model PricingLineItem {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  order      Int
  label      String
  quantity   Float    @default(1)
  unitPrice  Float
}

model Attachment {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  fileName   String
  storedPath String
  mimeType   String?
  createdAt  DateTime @default(now())
}

model ProposalEmbed {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  label      String?
  url        String
  kind       String
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    String
  createdAt  DateTime @default(now())
}
